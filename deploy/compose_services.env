# Lista servizi Compose usata dagli script cluster_* e dai test di integrazione Compose.
# Override rapido:
#   SDCC_SERVICES="node1,node2,node3,node4,node5,node6" scripts/cluster_up.sh
# oppure tramite file alternativo:
#   SDCC_SERVICES_FILE=/path/custom-services.env scripts/cluster_up.sh
SDCC_SERVICES="node1 node2 node3"
